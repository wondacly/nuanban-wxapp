.container {
  padding: 20rpx;
  padding-bottom: 160rpx;
}

/* 日记卡片 */
.diary-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.diary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.diary-date {
  font-weight: bold;
}

.diary-mood {
  display: flex;
  align-items: center;
  background: #FFF3E0;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.mood-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.mood-text {
  color: var(--primary-color);
}

.diary-content {
  margin-bottom: 20rpx;
}

.diary-text {
  line-height: 1.8;
  color: var(--text-secondary);
}

/* 照片 */
.diary-photos {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}

.diary-photo {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  margin: 0 16rpx 16rpx 0;
  background: #F5F5F5;
}

/* 元信息 */
.diary-meta {
  display: flex;
  justify-content: space-between;
  color: var(--text-light);
  padding-top: 20rpx;
  border-top: 2rpx solid #F5F5F5;
}

/* 添加按钮 */
.add-btn {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FF9F43, #FF7F00);
  color: #FFFFFF;
  padding: 24rpx 50rpx;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 159, 67, 0.3);
}

.add-btn:active {
  transform: translateX(-50%) scale(0.98);
}

.add-icon {
  font-size: 48rpx;
  margin-right: 12rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.empty-subtext {
  color: var(--text-light);
}