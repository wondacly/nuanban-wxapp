<view class="container">
  <!-- 日记列表 -->
  <view class="diary-list">
    <view class="diary-card" wx:for="{{diaries}}" wx:key="_id">
      <view class="diary-header">
        <text class="diary-date text-md">{{item.date}}</text>
        <view class="diary-mood">
          <text class="mood-icon">{{item.moodIcon}}</text>
          <text class="mood-text text-sm">{{item.mood}}</text>
        </view>
      </view>
      <view class="diary-content">
        <text class="diary-text text-md">{{item.content}}</text>
      </view>
      <view class="diary-photos" wx:if="{{item.photos.length > 0}}">
        <image class="diary-photo" wx:for="{{item.photos}}" wx:for-item="photo" wx:key="*this" src="{{photo}}" mode="aspectFill" bindtap="previewImage" data-src="{{photo}}"/>
      </view>
      <view class="diary-meta">
        <text class="text-sm">服务对象：{{item.elderlyName}}</text>
        <text class="text-sm">服务时长：{{item.duration}}</text>
      </view>
    </view>
  </view>

  <!-- 添加日记按钮 -->
  <view class="add-btn" bindtap="addDiary">
    <text class="add-icon">+</text>
    <text class="text-md">记录新的陪伴</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{diaries.length === 0}}">
    <text class="empty-icon">📝</text>
    <text class="empty-text text-md">暂无日记</text>
    <text class="empty-subtext text-sm">记录每次陪伴的美好时光</text>
  </view>
</view>