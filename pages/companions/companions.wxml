<view class="container">
  <!-- 筛选条件 -->
  <view class="filter-bar">
    <view class="filter-item {{currentFilter === 'distance' ? 'active' : ''}}" bindtap="setFilter" data-filter="distance">
      <text class="text-sm">距离最近</text>
    </view>
    <view class="filter-item {{currentFilter === 'rating' ? 'active' : ''}}" bindtap="setFilter" data-filter="rating">
      <text class="text-sm">评分最高</text>
    </view>
    <view class="filter-item {{currentFilter === 'count' ? 'active' : ''}}" bindtap="setFilter" data-filter="count">
      <text class="text-sm">服务最多</text>
    </view>
  </view>

  <!-- 服务类型标签 -->
  <view class="type-tags">
    <view class="type-tag {{currentType === 'all' ? 'active' : ''}}" bindtap="setType" data-type="all">
      <text class="text-sm">全部</text>
    </view>
    <view class="type-tag {{currentType === '1' ? 'active' : ''}}" bindtap="setType" data-type="1">
      <text class="text-sm">日常陪伴</text>
    </view>
    <view class="type-tag {{currentType === '2' ? 'active' : ''}}" bindtap="setType" data-type="2">
      <text class="text-sm">陪诊协助</text>
    </view>
    <view class="type-tag {{currentType === '3' ? 'active' : ''}}" bindtap="setType" data-type="3">
      <text class="text-sm">认知关怀</text>
    </view>
  </view>

  <!-- 陪伴者列表 -->
  <view class="companions-list">
    <view class="companion-item" wx:for="{{companions}}" wx:key="_id" bindtap="navigateToDetail" data-id="{{item._id}}">
      <image class="companion-avatar" src="{{item.avatar || '/images/default-avatar.png'}}" mode="aspectFill"/>
      <view class="companion-info">
        <view class="companion-header">
          <text class="companion-name text-md">{{item.name}}</text>
          <text class="companion-age text-sm">{{item.age}}岁</text>
          <view class="verified-badge" wx:if="{{item.isVerified}}">
            <text class="text-xs">✓ 已认证</text>
          </view>
        </view>
        <view class="companion-tags">
          <text class="tag tag-primary text-xs" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="index">{{tag}}</text>
        </view>
        <view class="companion-stats">
          <text class="stat text-sm">⭐ {{item.rating}}分</text>
          <text class="stat text-sm">服务{{item.serviceCount}}次</text>
          <text class="stat text-sm">📍 {{item.distance}}</text>
        </view>
      </view>
      <view class="contact-btn" catchtap="contactCompanion" data-id="{{item._id}}">
        <text class="text-sm">联系</text>
      </view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{loading}}">
    <text class="text-sm">加载中...</text>
  </view>
  <view class="no-more" wx:if="{{noMore}}">
    <text class="text-sm">没有更多了</text>
  </view>
</view>