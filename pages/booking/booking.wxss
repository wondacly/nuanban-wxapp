.container {
  padding: 20rpx;
  padding-bottom: 160rpx;
}

/* 陪伴者信息 */
.companion-bar {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.companion-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background: #F5F5F5;
}

.companion-info {
  flex: 1;
}

.companion-name {
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.companion-tags {
  color: var(--text-secondary);
}

/* 表单卡片 */
.form-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.form-title {
  font-weight: bold;
  display: block;
  margin-bottom: 24rpx;
}

/* 服务类型 */
.service-options {
  display: flex;
  justify-content: space-between;
}

.service-option {
  flex: 1;
  text-align: center;
  padding: 30rpx 16rpx;
  border-radius: 20rpx;
  background: #F5F5F5;
  margin: 0 8rpx;
  border: 4rpx solid transparent;
}

.service-option.active {
  background: var(--secondary-color);
  border-color: var(--primary-color);
}

.option-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 12rpx;
}

/* 日期选择 */
.date-options {
  display: flex;
  justify-content: space-between;
}

.date-option {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 16rpx;
  background: #F5F5F5;
  margin: 0 8rpx;
  border: 4rpx solid transparent;
}

.date-option.active {
  background: var(--secondary-color);
  border-color: var(--primary-color);
}

.date-weekday {
  color: var(--text-light);
  display: block;
  margin-bottom: 8rpx;
}

.date-day {
  font-weight: bold;
}

/* 时间选择 */
.time-options {
  display: flex;
  flex-wrap: wrap;
}

.time-option {
  width: calc(33.33% - 20rpx);
  text-align: center;
  padding: 24rpx 0;
  border-radius: 16rpx;
  background: #F5F5F5;
  margin: 10rpx;
  border: 4rpx solid transparent;
}

.time-option.active {
  background: var(--secondary-color);
  border-color: var(--primary-color);
}

/* 备注输入 */
.remark-input {
  width: 100%;
  min-height: 200rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
  border: none;
}

/* 安全提示 */
.safety-tips {
  padding: 20rpx;
  color: var(--warning-color);
  text-align: center;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.submit-btn.disabled {
  opacity: 0.5;
}