.container {
  padding: 20rpx;
}

.message-list {
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
}

.message-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #F5F5F5;
}

.message-item:last-child {
  border-bottom: none;
}

.message-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background: #F5F5F5;
}

.message-content {
  flex: 1;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.message-name {
  font-weight: bold;
}

.message-time {
  color: var(--text-light);
}

.message-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.message-text {
  color: var(--text-secondary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.message-text.unread {
  color: var(--text-primary);
  font-weight: bold;
}

.unread-badge {
  background: var(--warning-color);
  color: #FFFFFF;
  min-width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.empty-subtext {
  color: var(--text-light);
}