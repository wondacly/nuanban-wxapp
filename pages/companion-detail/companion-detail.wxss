.container {
  padding: 0 0 160rpx;
}

/* 顶部 */
.header {
  position: relative;
  padding: 60rpx 30rpx 40rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 300rpx;
  background: linear-gradient(135deg, #FF9F43, #FF7F00);
  border-radius: 0 0 40rpx 40rpx;
}

.header-content {
  position: relative;
  z-index: 1;
}

.avatar {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 6rpx solid #FFFFFF;
  background: #F5F5F5;
  margin-bottom: 20rpx;
}

.name {
  color: #FFFFFF;
  display: block;
  margin-bottom: 12rpx;
}

.basic-info {
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.9);
}

.divider {
  margin: 0 16rpx;
}

/* 信任标识 */
.trust-badges {
  display: flex;
  justify-content: center;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
}

.badge {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  margin: 0 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.badge-icon {
  margin-right: 8rpx;
}

.badge-text {
  color: var(--text-secondary);
}

/* 卡片 */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 0 20rpx 20rpx;
}

.card-title {
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}

/* 标签 */
.tags-list {
  display: flex;
  flex-wrap: wrap;
}

/* 自我介绍 */
.intro-text {
  line-height: 1.8;
  color: var(--text-secondary);
}

.intro-fold {
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.intro-toggle {
  color: var(--primary-color);
  margin-top: 12rpx;
  display: block;
}

/* 日历 */
.week-days {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.week-day {
  text-align: center;
  padding: 16rpx 0;
  flex: 1;
}

.day-name {
  color: var(--text-light);
  display: block;
  margin-bottom: 8rpx;
}

.day-date {
  font-weight: bold;
}

.time-slots {
  display: flex;
  flex-wrap: wrap;
}

.time-slot {
  width: calc(33.33% - 20rpx);
  margin: 10rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  text-align: center;
  border: 2rpx solid #EEEEEE;
}

.time-slot.available {
  background: #E8F8F0;
  border-color: var(--success-color);
}

.time-slot.booked {
  background: #F5F5F5;
  border-color: #EEEEEE;
  opacity: 0.5;
}

.slot-status {
  display: block;
  margin-top: 8rpx;
}

.time-slot.available .slot-status {
  color: var(--success-color);
}

/* 服务类型 */
.service-types {
  display: flex;
  justify-content: space-between;
}

.service-type {
  flex: 1;
  text-align: center;
  padding: 30rpx 20rpx;
  border-radius: 20rpx;
  background: #F5F5F5;
  margin: 0 10rpx;
  opacity: 0.4;
}

.service-type.active {
  background: var(--secondary-color);
  opacity: 1;
}

.type-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 12rpx;
}

/* 安全提示 */
.safety-tips {
  padding: 20rpx 30rpx;
  color: var(--warning-color);
  text-align: center;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.contact-btn {
  flex: 2;
  margin-right: 20rpx;
}

.book-btn {
  flex: 1;
}