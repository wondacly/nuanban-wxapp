/* 全局样式 - 适老化设计 */
page {
  --primary-color: #FF9F43;
  --secondary-color: #FFECD2;
  --success-color: #2ECC71;
  --warning-color: #E74C3C;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --bg-color: #FFF8F0;
  --card-bg: #FFFFFF;
  --border-radius: 16rpx;
  --spacing-sm: 20rpx;
  --spacing-md: 30rpx;
  --spacing-lg: 40rpx;
  
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  background-color: var(--bg-color);
  color: var(--text-primary);
  font-size: 36rpx;
  line-height: 1.6;
}

/* 大字体适配 */
.text-xl { font-size: 48rpx; font-weight: bold; }
.text-lg { font-size: 40rpx; font-weight: bold; }
.text-md { font-size: 36rpx; }
.text-sm { font-size: 32rpx; }
.text-xs { font-size: 28rpx; }

/* 按钮样式 - 最小88px点击区域 */
.btn {
  min-height: 100rpx;
  min-width: 100rpx;
  padding: 30rpx 50rpx;
  border-radius: 50rpx;
  font-size: 36rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.btn-primary {
  background: linear-gradient(135deg, #FF9F43, #FF7F00);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(255, 159, 67, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-secondary {
  background: #FFFFFF;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
}

/* 卡片样式 */
.card {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  margin: 6rpx;
}

.tag-primary {
  background: var(--secondary-color);
  color: var(--primary-color);
}

.tag-success {
  background: #E8F8F0;
  color: var(--success-color);
}

/* 安全区域 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
}

/* 通用flex布局 */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }
.justify-center { justify-content: center; }
.flex-1 { flex: 1; }

/* 间距 */
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-20 { margin-bottom: 20rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

/* 文字颜色 */
.text-primary { color: var(--text-primary); }
.text-secondary { color: var(--text-secondary); }
.text-light { color: var(--text-light); }
.text-white { color: #FFFFFF; }

/* 单行省略 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 多行省略 */
.ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}